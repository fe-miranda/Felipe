{
  "expo": {
    "name": "GymAI",
    "slug": "gymapp-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymapp.ai",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSPhotoLibraryUsageDescription": "O GymAI precisa de acesso à galeria para importar fotos do seu plano de treino.",
        "NSCameraUsageDescription": "O GymAI precisa da câmera para fotografar seu plano de treino.",
        "NSMicrophoneUsageDescription": "O GymAI precisa do microfone para gravação de áudio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6c47ff"
      },
      "package": "com.gymapp.ai",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#7C3AED",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O GymAI precisa de acesso à sua galeria para importar fotos do plano de treino.",
          "cameraPermission": "O GymAI precisa da câmera para fotografar seu plano de treino."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "O GymAI precisa de acesso à sua galeria.",
          "savePhotosPermission": "O GymAI precisa salvar imagens do treino.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-av"
    ]
  }
}
